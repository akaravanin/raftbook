# Copy this to .env and adjust for your environment.
# The defaults below match the docker-compose dev setup.

# Postgres connection string
DATABASE_URL=postgres://raftbook:raftbook@localhost:5432/raftbook

# Server bind addresses (optional — these are the defaults)
GRPC_ADDR=0.0.0.0:50051
HTTP_ADDR=0.0.0.0:8080

# Log level (optional)
RUST_LOG=engined=info,api=debug,command_handler=debug
